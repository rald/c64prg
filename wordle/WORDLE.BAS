1100 DIM W$(211)
1101 DIM C(5)
1110 K=0
1120 PRINT CHR$(147);"WORDLE";CHR$(13)
1121 POKE 646, 1: PRINT "WHITE";: POKE 646,14: PRINT " LETTER IS CORRECT"
1122 POKE 646, 5: PRINT "GREEN";: POKE 646,14: PRINT " LETTER IS MISPLACE - SYMBOL '^'"
1123 POKE 646, 7: PRINT "YELLOW";: POKE 646,14: PRINT " LETTER IS WRONG - SYMBOL '?'"
1130 PRINT CHR$(13);"PRESS ENTER KEY...";
1140 GET A$: IF A$<>CHR$(13) THEN K=K+1: GOTO 1140
1145 PRINT CHR$(147);
1150 T=RND(-K)
1160 GOSUB 3000: REM READ DATA
1170 GOSUB 4000: REM GET RANDOM WORD
1175 FOR L=1 TO 6
1176 POKE 646,3
1177 PRINT MID$(STR$(L),2);". ";
1180 INPUT "GUESS:";G$
1190 IF LEN(G$)<>5 THEN PRINT "MUST BE 4 CHARACTERS":GOTO 1176
1191 GOSUB 5000: REM CHECK IF VALID CHARACTERS
1192 IF V=0 THEN PRINT "MUST BE ALL LETTERS": GOTO 1176
1220 GOSUB 7000: REM SHOW CLUE 
1250 IF C(1)=1 AND C(2)=1 AND C(3)=1 AND C(4)=1 AND C(5)=1 THEN 1270
1260 NEXT L
1261 PRINT "WRONG IT IS ";CHR$(34);W$;CHR$(34)
1262 GOTO 1280
1263 PRINT "CORRECT IT IS ";CHR$(34);W$;CHR$(34)
1280 END

3000 REM READ DATA
3010 FOR I=0 TO 211
3020 READ W$(I)
3030 NEXT I
3040 RETURN

4000 REM GET RANDOM WORD
4010 I=INT(RND(1)*212)
4020 W$=W$(I)
4030 RETURN

5000 REM CHECK IF VALID CHARACTERS
5010 V=1
5020 FOR I=1 TO 5
5030 C$=MID$(G$,I,1)
5040 IF C$<"A" OR C$>"Z" THEN V=0: GOTO 5060
5050 NEXT I
5060 RETURN

7000 REM SHOW CLUE
7010 FOR I=1 TO 5:C(I)=7:NEXT I
7020 FOR I=1 TO 5
7021 A$=MID$(G$,I,1)
7022 B$=MID$(W$,I,1)
7030 IF A$=B$ THEN C(I)=1
7040 NEXT I
7050 FOR J=1 TO 5
7060 FOR I=1 TO 5
7065 IF I=J THEN 7080
7066 A$=MID$(G$,J,1)
7067 B$=MID$(W$,I,1)
7070 IF C(J)=7 AND A$=B$ THEN C(J)=5
7080 NEXT I
7090 NEXT J
7100 FOR I=1 TO 5
7105 POKE 646,C(I): PRINT MID$(G$,I,1);
7120 NEXT I
7121 POKE 646,3
7130 PRINT CHR$(13);
7140 FOR I=1 TO 5
7150 IF C(I)=1 THEN PRINT MID$(G$,I,1);
7160 IF C(I)=5 THEN PRINT "^";
7170 IF C(I)=7 THEN PRINT "?";
7180 NEXT I
7190 PRINT CHR$(13);
7200 RETURN
