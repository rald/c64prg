1000 W%=10
1010 H%=10
1020 M%=10
1030 X%=0
1040 Y%=0
1050 G%=W%*H%-M%
1060 N%=0
1070 DIM B%(W%-1,H%-1)
1080 S=TI
1090 O%=0
1100 GOSUB 1210
1110 GOSUB 1320
1120 GOSUB 1460
1130 IF B%(X%,Y%)=9 THEN B%(X%,Y%)=11: O%=1: GOSUB 1320: GOTO 1820
1140 IF B%(X%,Y%)=10 THEN GOSUB 1510: GOSUB 1670
1150 IF G%=0 THEN 1170
1160 GOTO 1110
1170 GOSUB 1320
1180 PRINT CHR$(5);"FINISHED"
1190 PRINT "TIME";INT((TI-S)/60);"SECONDS"
1200 GOTO 1820

1210 FOR J=0 TO H%-1:FOR I=0 TO W%-1:B%(I,J)=10:NEXT I:NEXT J
1220 FOR I=0 TO M%-1
1230 X%=INT(RND(1)*10)
1240 Y%=INT(RND(1)*10)
1250 IF B%(X%,Y%)=9 THEN X%=X%+1
1260 IF B%(X%,Y%)=10 THEN B%(X%,Y%)=9: GOTO 1300
1270 IF X%>=W% THEN X%=0: Y%=Y+1
1280 IF Y%>=H% THEN X%=0: Y%=0
1290 GOTO 1260
1300 NEXT I
1310 RETURN

1320 PRINT CHR$(147);CHR$(5);"MINESWEEPER"
1330 PRINT CHR$(30);" 0123456789"
1340 FOR J=0 TO H%-1
1350 PRINT CHR$(30);MID$(STR$(J),2);
1360 FOR I=0 TO W%-1
1370 IF B%(I,J)=0 THEN PRINT " ";: GOTO 1420
1380 IF B%(I,J)>=1 AND B%(I,J)<=8 THEN PRINT CHR$(144);MID$(STR$(B%(I,J)),2);: GOTO 1420
1390 IF B%(I,J)=11 THEN PRINT CHR$(28);"X";: GOTO 1420
1400 IF O%=1 AND B%(I,J)=9 THEN PRINT CHR$(28);"*";: GOTO 1420
1410 PRINT CHR$(144);".";
1420 NEXT I
1430 PRINT CHR$(13);
1440 NEXT J
1450 RETURN

1460 PRINT CHR$(5);
1470 INPUT "INPUT X,Y"; X%,Y%
1480 IF X%<0 OR X%>=W% THEN PRINT "X AXIS OUT OF BOUNDS": GOTO 1470
1490 IF Y%<0 OR Y%>=H% THEN PRINT "Y AXIS OUT OF BOUNDS": GOTO 1470
1500 RETURN

1510 IF X%<0 OR X%>=W% OR Y%<0 OR Y%>=H% THEN RETURN 
1520 IF B%(X%,Y%)<>10 THEN RETURN
1530 N%=0
1540 PRINT CHR$(5);"SWEEPING";X%;",";Y%
1550 FOR J=-1 TO 1
1560 FOR I=-1 TO 1
1570 IF I=0 AND J=0 THEN 1610
1580 IF X%+I<0 OR X%+I>=W% THEN 1610
1590 IF Y%+J<0 OR Y%+J>=H% THEN 1610
1600 IF B%(X%+I,Y%+J)=9 THEN N%=N%+1
1610 NEXT I
1620 NEXT J
1630 G%=G%-1
1640 IF N%=0 THEN B%(X%,Y%)=12:GOTO 1660
1650 B%(X%,Y%)=N%
1660 RETURN

1670 F%=0
1680 FOR L=0 TO H%-1
1690 FOR K=0 TO W%-1
1700 IF B%(K,L)<>12 THEN 1780
1710 FOR V=-1 TO 1
1720 FOR U=-1 TO 1
1730 IF U=0 AND V=0 THEN 1760
1740 X%=K+U: Y%=L+V: B%(K,L)=0: F%=1
1750 GOSUB 1510
1760 NEXT U
1770 NEXT V
1780 NEXT K
1790 NEXT L
1800 IF F%=1 THEN 1670
1810 RETURN

1820 PRINT CHR$(5);
1830 PRINT "GAME OVER"
1840 END


