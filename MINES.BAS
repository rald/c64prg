1000 T=RND(-TI)
1010 W=10:H=10:M=10
1020 G=W*H-M
1030 O=0
1040 DIM B(W-1,H-1)
1050 DIM SX(W*H-1)
1060 DIM SY(W*H-1)
1070 SP=W*H
1071 SC=TI

1090 REM MAIN LOOP
1100 PRINT CHR$(147);
1110 GOSUB 2000: REM CLEAR BOARD
1120 GOSUB 3000: REM PLANT MINES
1130 GOSUB 4000: REM DISPLAY BOARD
1140 GOSUB 5000: REM GET INPUT
1150 SP=SP-1: SX(SP)=X: SY(SP)=Y
1160 GOSUB 6000: REM OPEN CELL
1170 IF SP<W*H THEN 1160
1180 IF G>0 AND O=0 THEN 1130
1185 GOSUB 4000: REM DISPLAY BOARD
1190 PRINT CHR$(5);"TIME";INT((TI-SC)/60);"SECONDS"
1200 PRINT CHR$(5);"GAME OVER"
1220 END

2000 REM CLEAR BOARD
2005 PRINT "CLEARING BOARD..."
2010 FOR J=0 TO H-1
2020 FOR I=0 TO W-1
2030 B(I,J)=10
2040 NEXT I
2050 NEXT J
2060 RETURN

3000 REM INIT BOARD
3005 PRINT "PLANTING MINES..."
3010 FOR K=1 TO M
3020 I=INT(RND(1)*W)
3030 J=INT(RND(1)*H)
3040 IF B(I,J)<>9 THEN 3110 
3050 I=I+1
3060 IF I<W THEN 3040 
3070 I=0: J=J+1
3080 IF J<H THEN 3040
3090 I=0: J=0
3100 GOTO 3040
3110 B(I,J)=9
3120 NEXT K
3130 RETURN

4000 REM DISPLAY BOARD
4001 PRINT CHR$(147);CHR$(5);"MINESWEEPER"
4005 PRINT CHR$(30);" 0123456789"
4010 FOR J=0 TO H-1
4015 PRINT CHR$(30);MID$(STR$(J),2);
4020 FOR I=0 TO W-1
4030 N=B(I,J)
4040 IF N=0 THEN PRINT " ";:GOTO 4090
4050 IF N>=1 AND N<=8 THEN PRINT CHR$(5);MID$(STR$(N),2);:GOTO 4090
4060 IF N=9 AND O=1 THEN PRINT CHR$(28);"*";:GOTO 4090
4070 IF N=11 THEN PRINT CHR$(28);"X";:GOTO 4090
4080 PRINT CHR$(144);".";
4090 NEXT I
4095 PRINT
4100 NEXT J
4110 RETURN

5000 REM GET INPUT
5001 PRINT CHR$(5);
5010 INPUT "INPUT X,Y"; X,Y
5020 IF X<0 OR X>=W THEN PRINT "X IS INVALID": GOTO 5010
5030 IF Y<0 OR Y>=H THEN PRINT "Y IS INVALID": GOTO 5010
5040 RETURN

6000 REM OPEN CELL
6010 IF SP>=W*H THEN RETURN
6020 X=SX(SP): Y=SY(SP): SP=SP+1
6030 IF X<0 OR X>=W OR Y<0 OR Y>=H THEN RETURN
6040 IF B(X,Y)=9 THEN B(X,Y)=11: O=1: RETURN
6050 IF B(X,Y)<>10 AND B(X,Y)<>12 THEN RETURN
6061 PRINT "SWEEPING";X;",";Y
6060 N=0
6070 FOR V=-1 TO 1
6080 FOR U=-1 TO 1
6090 IF U=0 AND V=0 THEN 6110
6091 D=X+U: E=Y+V
6092 IF D<0 OR D>=W OR E<0 OR E>=H THEN 6110
6100 IF B(D,E)=9 THEN N=N+1
6110 NEXT U
6120 NEXT V
6130 B(X,Y)=N
6131 G=G-1
6140 IF N<>0 THEN RETURN
6150 FOR V=-1 TO 1
6160 FOR U=-1 TO 1
6170 IF U=0 AND V=0 THEN 6230
6180 D=X+U: E=Y+V
6190 IF D<0 OR D>=W OR E<0 OR E>=H THEN 6230
6200 IF B(D,E)<>10 THEN 6230
6210 B(D,E)=12
6220 SP=SP-1: SX(SP)=D: SY(SP)=E
6230 NEXT U
6240 NEXT V
6250 RETURN
