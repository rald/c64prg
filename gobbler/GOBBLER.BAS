10 PRINT CHR$(147):DIM B(2,2),S(2,2),H(3),C(3),ST(2,2,3),OW(2,2,3),K(2,2)
15 X=RND(-TI)
20 FOR I=1 TO 3:H(I)=2:C(I)=2:NEXT:T=0:REM PIECES SET TO 2 EACH
30 GOSUB 500:IF T=1 GOTO 300
40 PRINT "1:NEW 2:MOVE":INPUT M
50 IF M=2 GOTO 100
60 INPUT "NEW (A-C),R,C";P$,R,L:P=ASC(P$)-64
70 IF P<1 OR P>3 OR R<0 OR R>2 OR L<0 OR L>2 GOTO 60
80 IF H(P)=0 OR P<=S(R,L) THEN PRINT "BAD MOVE":GOTO 60
85 K(R,L)=K(R,L)+1:D=K(R,L):ST(R,L,D)=P:OW(R,L,D)=1
90 B(R,L)=1:S(R,L)=P:H(P)=H(P)-1:GOSUB 700:GOTO 400
100 INPUT "MOVE R0,C0,R1,C1";R1,C1,R,L
110 IF B(R1,C1)<>1 OR S(R1,C1)<=S(R,L) THEN PRINT "CANT":GOTO 40
120 P=S(R1,C1):K(R1,C1)=K(R1,C1)-1:D=K(R1,C1)
122 IF D=0 THEN B(R1,C1)=0:S(R1,C1)=0:GOTO 125
123 B(R1,C1)=OW(R1,C1,D):S(R1,C1)=ST(R1,C1,D)
125 K(R,L)=K(R,L)+1:D=K(R,L):ST(R,L,D)=P:OW(R,L,D)=1
126 B(R,L)=1:S(R,L)=P:GOSUB 700:GOTO 400
300 PRINT "CPU THINKING..."
310 P=INT(RND(1)*3)+1:IF C(P)=0 GOTO 310
320 R=INT(RND(1)*3):L=INT(RND(1)*3)
330 IF P<=S(R,L) GOTO 320
380 K(R,L)=K(R,L)+1:D=K(R,L):ST(R,L,D)=P:OW(R,L,D)=2
385 B(R,L)=2:S(R,L)=P:C(P)=C(P)-1:GOSUB 700
400 T=1-T:IF W=0 GOTO 30
410 GOSUB 500:IF W=1 THEN PRINT "YOU WIN!":END
420 PRINT "CPU WINS!":END
500 PRINT CHR$(147);"    0  1  2";CHR$(13):FOR I=0 TO 2:PRINT I;
510 FOR J=0 TO 2:PRINT "[";:V=B(I,J):IF V=0 THEN PRINT " ";:GOTO 540
520 IF V=1 THEN PRINT CHR$(64+S(I,J));:GOTO 540
530 PRINT CHR$(48+S(I,J));
540 PRINT "]";:NEXT J:PRINT:NEXT I
550 PRINT "-------------------"
560 PRINT "YOU:";:FOR I=1 TO 3:FOR J=1 TO H(I):PRINT CHR$(64+I);:NEXT J,I:PRINT
570 PRINT "CPU:";:FOR I=1 TO 3:FOR J=1 TO C(I):PRINT CHR$(48+I);:NEXT J,I:PRINT
580 PRINT "-------------------":RETURN
700 W=0:FOR I=0 TO 2
710 IF B(I,0)>0 AND B(I,0)=B(I,1) AND B(I,0)=B(I,2) THEN W=B(I,0)
720 IF B(0,I)>0 AND B(0,I)=B(1,I) AND B(0,I)=B(2,I) THEN W=B(0,I)
730 NEXT I:IF W>0 THEN RETURN
740 IF B(0,0)>0 AND B(0,0)=B(1,1) AND B(0,0)=B(2,2) THEN W=B(0,0)
750 IF B(0,2)>0 AND B(0,2)=B(1,1) AND B(0,2)=B(2,0) THEN W=B(0,2)
760 RETURN
