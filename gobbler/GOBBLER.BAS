10 PRINT CHR$(147):DIM B(2,2),S(2,2,3),H(3),C(3):X=RND(-TI)
20 FOR I=1 TO 3:H(I)=2:C(I)=2:NEXT:T=0
30 GOSUB 500:IF T=1 GOTO 300
40 PRINT "1:NEW 2:MOVE":INPUT M
50 IF M=2 GOTO 100
60 INPUT "PC(A-C),R,C";P$,R,L:P=ASC(P$)-64
70 IF P<1 OR P>3 OR R<0 OR R>2 OR L<0 OR L>2 GOTO 60
80 GOSUB 800:IF H(P)=0 OR P<=V THEN PRINT "BAD MOVE":GOTO 60
90 GOSUB 820:S(R,L,V)=10+P:B(R,L)=1:H(P)=H(P)-1:GOSUB 700:GOTO 400
100 INPUT "FROM R,C TO R,C";R1,C1,R,L
105 IF R1<0 OR R1>2 OR C1<0 OR C1>2 OR R<0 OR R>2 OR L<0 OR L>2 GOTO 100
110 TR=R:TL=L:R=R1:L=C1:GOSUB 800:P=V:IF B(R1,C1)<>1 OR P=0 GOTO 115
112 R=TR:L=TL:GOSUB 800:IF P<=V THEN PRINT "CANT GOBBLE":GOTO 40
113 GOTO 120
115 PRINT "INVALID SELECTION":GOTO 40
120 R=R1:L=C1:GOSUB 800:S(R,L,SP)=0:GOSUB 800:B(R,L)=INT(VO/10)
125 R=TR:L=TL:GOSUB 820:S(R,L,V)=10+P:B(R,L)=1:GOSUB 700:GOTO 400
300 PRINT "CPU THINKING...":FOR R=0 TO 2:FOR L=0 TO 2:V1=B(R,L):GOSUB 800:SS=V
310 FOR P=3 TO 1 STEP -1:IF C(P)=0 OR P<=SS GOTO 340
320 B(R,L)=2:GOSUB 700:IF W=2 GOTO 380
330 B(R,L)=1:GOSUB 700:IF W=1 THEN B(R,L)=2:W=0:GOTO 380
340 B(R,L)=V1:NEXT P,L,R
350 P=INT(RND(1)*3)+1:R=INT(RND(1)*3):L=INT(RND(1)*3)
360 GOSUB 800:IF C(P)=0 OR P<=V GOTO 350
380 B(R,L)=2:GOSUB 820:S(R,L,V)=20+P:C(P)=C(P)-1:GOSUB 700
400 T=1-T:IF W=0 GOTO 30
410 GOSUB 500:IF W=1 THEN PRINT "YOU WIN!":END
420 PRINT "CPU WINS!":END
500 PRINT CHR$(147);"      0   1   2";CHR$(13):FOR I=0 TO 2:PRINT I;
510 FOR J=0 TO 2:PRINT " [";:IF B(I,J)=0 THEN PRINT " ";:GOTO 540
515 R=I:L=J:GOSUB 800:P=V
520 IF B(I,J)=1 THEN PRINT CHR$(64+P);:GOTO 540
530 PRINT CHR$(48+P);
540 PRINT "]";:NEXT J:PRINT CHR$(13):NEXT I
550 PRINT "-------------------"
560 PRINT "YOU (A,B,C):";H(1);H(2);H(3)
570 PRINT "CPU (1,2,3):";C(1);C(2);C(3)
580 PRINT "-------------------":RETURN
700 W=0:FOR I=0 TO 2
710 IF B(I,0)>0 AND B(I,0)=B(I,1) AND B(I,0)=B(I,2) THEN W=B(I,0)
720 IF B(0,I)>0 AND B(0,I)=B(1,I) AND B(0,I)=B(2,I) THEN W=B(0,I)
730 NEXT I:IF W>0 THEN RETURN
740 IF B(0,0)>0 AND B(0,0)=B(1,1) AND B(0,0)=B(2,2) THEN W=B(0,0)
750 IF B(0,2)>0 AND B(0,2)=B(1,1) AND B(0,2)=B(2,0) THEN W=B(0,2)
760 RETURN
800 REM GET TOP: R,L IN -> V=SIZE, VO=FULL, SP=POS
810 V=0:VO=0:SP=0:FOR K=3 TO 1 STEP -1:IF S(R,L,K)>0 THEN VO=S(R,L,K):V=VO-INT(VO/10)*10:SP=K:K=1
815 NEXT:RETURN
820 REM FIND EMPTY: R,L IN -> V=POS
830 V=0:FOR K=1 TO 3:IF S(R,L,K)=0 THEN V=K:K=3
840 NEXT:RETURN