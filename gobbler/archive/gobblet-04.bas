10 PRINT CHR$(147):DIM B(2,2),S(2,2),H(3),C(3):X=RND(-TI)
20 FOR I=1 TO 3:H(I)=2:C(I)=2:NEXT:T=0
30 GOSUB 500:IF T=1 GOTO 300
40 PRINT "1:NEW PIECE  2:MOVE PIECE":INPUT M
50 IF M=2 GOTO 100
60 INPUT "NEW PIECE (A-C),R,C";P$,R,L:P=ASC(P$)-64
70 IF P<1 OR P>3 OR R<0 OR R>2 OR L<0 OR L>2 GOTO 60
80 IF H(P)=0 OR P<=S(R,L) THEN PRINT "BAD MOVE":GOTO 60
90 B(R,L)=1:S(R,L)=P:H(P)=H(P)-1:GOSUB 700:GOTO 400
100 INPUT "MOVE PIECE R0,C0,R1,C1";R1,C1,R,L
110 IF B(R1,C1)<>1 OR S(R1,C1)<=S(R,L) THEN PRINT "CANT":GOTO 40
120 P=S(R1,C1):B(R1,C1)=0:S(R1,C1)=0:B(R,L)=1:S(R,L)=P
130 GOSUB 700:GOTO 400
300 PRINT "CPU THINKING...":Z=0
310 M=INT(RND(1)*2)+1:IF M=2 GOTO 350
320 P=INT(RND(1)*3)+1:R=INT(RND(1)*3):L=INT(RND(1)*3):Z=Z+1
330 IF Z>50 GOTO 350
340 IF C(P)=0 OR P<=S(R,L) GOTO 320
345 B(R,L)=2:S(R,L)=P:C(P)=C(P)-1:GOSUB 700:GOTO 400
350 R1=INT(RND(1)*3):C1=INT(RND(1)*3):R=INT(RND(1)*3):L=INT(RND(1)*3)
360 IF B(R1,C1)<>2 OR S(R1,C1)<=S(R,L) GOTO 310
370 P=S(R1,C1):B(R1,C1)=0:S(R1,C1)=0:B(R,L)=2:S(R,L)=P:GOSUB 700
400 T=1-T:IF W=0 GOTO 30
410 GOSUB 500:IF W=1 THEN PRINT "YOU WIN!":END
420 PRINT "CPU WINS!":END
500 PRINT CHR$(147);"     0   1   2";CHR$(13):FOR I=0 TO 2:PRINT I;
510 FOR J=0 TO 2:PRINT " [";:V=B(I,J):IF V=0 THEN PRINT " ";:GOTO 540
520 IF V=1 THEN PRINT CHR$(64+S(I,J));:GOTO 540
530 PRINT CHR$(48+S(I,J));
540 PRINT "]";:NEXT J:PRINT CHR$(13):NEXT I
550 PRINT "-------------------"
560 PRINT "YOU (A,B,C):";H(1);H(2);H(3)
570 PRINT "CPU (1,2,3):";C(1);C(2);C(3)
580 PRINT "-------------------":RETURN
700 W=0:FOR I=0 TO 2
710 IF B(I,0)>0 AND B(I,0)=B(I,1) AND B(I,0)=B(I,2) THEN W=B(I,0)
720 IF B(0,I)>0 AND B(0,I)=B(1,I) AND B(0,I)=B(2,I) THEN W=B(0,I)
730 NEXT I:IF W>0 THEN RETURN
740 IF B(0,0)>0 AND B(0,0)=B(1,1) AND B(0,0)=B(2,2) THEN W=B(0,0)
750 IF B(0,2)>0 AND B(0,2)=B(1,1) AND B(0,2)=B(2,0) THEN W=B(0,2)
760 RETURN