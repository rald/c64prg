1000 REM BOGGLET BOGGLER
1010 PL=0
1020 DIM B$(2,2,2):DIM P(2,2)
1030 FOR Z=0 TO 2:FOR Y=0 TO 2:FOR X=0 TO 2:B$(X,Y,Z)=".":NEXT X,Y,Z
1040 FOR Y=0 TO 2:FOR X=0 TO 2:P(X,Y)=0:NEXT X,Y
1050 P0$="AABBCC":P1$="112233"
1060 PRINT CHR$(147);
1070 GOSUB 2000: REM PRINT BOARD
1080 IF PL=0 THEN GOSUB 3000: REM GET INPUT
1090 IF PL=1 THEN GOSUB 9000: REM CPU MOVE
1100 GOSUB 10000: REM CHECK WIN
1110 GOSUB 8000: REM PRESS ENTER KEY
1120 GOTO 1060

2000 REM PRINT BOARD
2010 FOR Y=0 TO 2
2020 FOR X=0 TO 2
2030 PRINT B$(X,Y,P(X,Y));
2040 NEXT X
2050 PRINT
2060 NEXT Y
2070 PRINT
2080 RETURN 

3000 REM GET INPUT
3010 PRINT "COMMANDS"
3020 PRINT "S <PIECE> <X> <Y>"
3030 PRINT "B <X0> <Y0> <X1> <Y1>"
3040 INPUT "COMMAND";L$
3050 C$=LEFT$(L$,1)
3060 IF C$="S" THEN GOSUB 4000
3070 IF C$="B" THEN GOSUB 5000
3080 RETURN

4000 REM PARSE S PIECE X Y
4010 P=3
4020 P$=MID$(L$,P,1)
4030 X=VAL(MID$(L$,P+2,1))
4040 Y=VAL(MID$(L$,P+4,1))
4050 GOSUB 6000: REM PROCESS S
4060 RETURN

5000 REM PARSE B X0 Y0 X1 Y1
5010 P=3
5020 X0=VAL(MID$(L$,P,1))
5030 Y0=VAL(MID$(L$,P+2,1))
5040 X1=VAL(MID$(L$,P+4,1))
5050 Y1=VAL(MID$(L$,P+6,1))
5060 GOSUB 7000: REM PROCESS B
5070 RETURN

6000 REM PROCESS S
6010 PRINT "S";P$;X;Y
6020 GOSUB 8000: REM PRESS ANY KEY
6030 RETURN

7000 REM PROCESS B
7010 PRINT "B";X0;Y0;X1;Y1
7020 GOSUB 8000: REM PRESS ANY KEY
7030 RETURN

8000 REM PRESS ENTER KEY
8010 PRINT "PRESS ENTER KEY...";
8020 GET A$: IF A$<>CHR$(13) THEN 8020
8030 PRINT
8040 RETURN

9000 REM CPU MOVE
9010 PRINT "CPU MOVE"
9020 GOSUB 8000: REM PRESS ANY KEY
9030 RETURN

10000 REM CHECK WIN
10010 PRINT "CHECK WIN"
10020 GOSUB 8000: REM PRESS ANY KEY
10030 RETURN

