1000 REM BOGGLET BOGGLER
1010 PL=0
1020 DIM B$(2,2,2):DIM P(2,2)
1030 FOR Z=0 TO 2:FOR Y=0 TO 2:FOR X=0 TO 2:B$(X,Y,Z)=".":NEXT X,Y,Z
1040 FOR Y=0 TO 2:FOR X=0 TO 2:P(X,Y)=0:NEXT X,Y
1050 P0$="AABBCC":P1$="112233"
1060 PRINT CHR$(147);
1070 GOSUB 2000: REM PRINT BOARD
1080 IF PL=0 THEN GOSUB 3000: REM GET INPUT
1090 IF PL=1 THEN GOSUB 9000: REM CPU MOVE
1100 GOSUB 10000: REM CHECK WIN
1110 GOSUB 8000: REM PRESS ENTER KEY
1120 PL=1-PL
1120 GOTO 1060

2000 REM PRINT BOARD
2010 FOR Y=0 TO 2
2020 FOR X=0 TO 2
2030 PRINT B$(X,Y,P(X,Y));
2040 NEXT X
2050 PRINT
2060 NEXT Y
2070 PRINT
2080 RETURN 

3000 REM GET INPUT
3010 PRINT "COMMANDS"
3020 PRINT "S <PIECE> <X> <Y>"
3030 PRINT "B <X0> <Y0> <X1> <Y1>"
3040 INPUT "COMMAND";L$
3050 C$=LEFT$(L$,1)
3060 IF C$="S" THEN GOSUB 4000
3070 IF C$="B" THEN GOSUB 5000
3080 RETURN

4000 REM PARSE S PIECE X Y
4010 P=3
4020 P$=MID$(L$,P,1)
4030 X=VAL(MID$(L$,P+2,1))
4040 Y=VAL(MID$(L$,P+4,1))
4050 GOSUB 6000: REM PROCESS S
4060 RETURN

5000 REM PARSE B X0 Y0 X1 Y1
5010 P=3
5020 X0=VAL(MID$(L$,P,1))
5030 Y0=VAL(MID$(L$,P+2,1))
5040 X1=VAL(MID$(L$,P+4,1))
5050 Y1=VAL(MID$(L$,P+6,1))
5060 GOSUB 7000: REM PROCESS B
5070 RETURN

6000 REM PROCESS S
6010 PRINT PL;"S";P$;X;Y
6020 IF X<0 OR X>2 THEN PRINT "INVALID X": RETURN
6030 IF Y<0 OR Y>2 THEN PRINT "INVALID Y": RETURN
6040 IF PL=0 THEN 6070
6050 IF PL=1 THEN 6140
6060 RETURN 
6070 IF P$<"A" OR P$>"C" THEN PRINT "INVALID PIECE": RETURN
6080 B$=B$(X,Y,P(X,Y))
6090 IF B$="." THEN GOSUB 6210: RETURN
6100 IF B$="A" AND P$="B" THEN GOSUB 6210: RETURN 
6110 IF (B$="A" OR B$="B") AND P$="C" GOSUB 6210: RETURN
6120 PRINT "INVALID MOVE"
6130 RETURN
6140 IF P$<"1" OR P$>"3" THEN PRINT "INVALID PIECE": RETURN
6150 B$=B$(X,Y,P(X,Y))
6160 IF B$="." THEN GOSUB 6210: RETURN
6170 IF B$="1" AND P$="2" THEN GOSUB 6210: RETURN
6180 IF (B$="1" OR B$="2") AND P$="3" THEN GOSUB 6210: RETURN
6190 PRINT "INVALID MOVE"
6200 RETURN
6210 B$(X,Y,P(X,Y))=P$
6220 P(X,Y)=P(X,Y)+1
6230 RETURN 

7000 REM PROCESS B
7010 PRINT PL;"B";X0;Y0;X1;Y1
7020 IF X0<0 OR X0>2 THEN PRINT "INVALID X0": RETURN
7030 IF Y0<0 OR Y0>2 THEN PRINT "INVALID Y0": RETURN
7040 IF X1<0 OR X1>2 THEN PRINT "INVALID X1": RETURN
7050 IF Y1<0 OR Y1>2 THEN PRINT "INVALID Y1": RETURN
7060 IF PL=0 THEN 7090
7070 IF PL=1 THEN 7200
7080 RETURN
7090 B0$=B$(X0,Y0,P(X0,Y0)-1)
7100 IF B0$="." THEN PRINT "LOCATION";X;",";Y;"IS EMPTY": RETURN
7110 IF P(X1,Y1)=0 THEN GOSUB 7170: RETURN
7120 B1$=B$(X1,Y1,P(X1,Y1)-1)
7130 IF B0$="B" AND (B1$="A" OR B1$="1") THEN GOSUB 7170: RETURN
7140 IF B0$="C" AND (B1$="A" OR B1$="B" OR B1$="1" OR B1$="2") THEN GOSUB 7170: RETURN
7150 PRINT "INVALID MOVE"
7160 RETURN
7170 P(X0,Y0)=P(X0,Y0)-1: B$(X0,Y0,P(X0,Y0))="."
7180 B$(X1,Y1,P(X1,Y1))=B0$: P(X1,Y1)=P(X1,Y1)+1
7190 RETURN
7200 B0$=B$(X0,Y0,P(X0,Y0)-1)
7290 IF B0$="." THEN PRINT "LOCATION";X;",";Y;"IS EMPTY": RETURN
7210 IF P(X1,Y1)=0 THEN GOSUB 7270: RETURN
7220 B1$=B$(X1,Y1,P(X1,Y1)-1)
7230 IF B0$="2" AND (B1$="A" OR B1$="1") THEN GOSUB 7270: RETURN
7240 IF B0$="3" AND (B1$="A" OR B1$="B" OR B1$="1" OR B1$="2") THEN GOSUB 7270: RETURN
7250 PRINT "INVALID MOVE"
7260 RETURN
7270 P(X0,Y0)=P(X0,Y0)-1: B$(X0,Y0,P(X0,Y0))="."
7280 B$(X1,Y1,P(X1,Y1))=B0$: P(X1,Y1)=P(X1,Y1)+1
7290 RETURN

8000 REM PRESS ENTER KEY
8010 PRINT "PRESS ENTER KEY...";
8020 GET A$: IF A$<>CHR$(13) THEN 8020
8030 PRINT
8040 RETURN

9000 REM CPU MOVE
9010 PRINT "CPU MOVE"
9020 GOSUB 8000: REM PRESS ANY KEY
9030 RETURN

10000 REM CHECK WIN
10010 PRINT "CHECK WIN"
10020 GOSUB 8000: REM PRESS ANY KEY
10030 RETURN

